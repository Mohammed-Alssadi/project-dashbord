{
  "name": "project-dashboard-backend",
  "version": "1.0.0",
  "description": "Express backend for store dashboard connecting to Salla and Zid using MySQL",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch .env --watch src --watch server.js server.js",
    "db:migrate": "sequelize-cli db:migrate --models-path src/models --migrations-path database/migrations --config src/config/config.cjs",
    "db:migrate:undo": "sequelize-cli db:migrate:undo --models-path src/models --migrations-path database/migrations --config src/config/config.cjs",
    "db:seed": "sequelize-cli db:seed:all --models-path src/models --seeders-path database/seeders --config src/config/config.cjs",
    "db:seed:undo": "sequelize-cli db:seed:undo:all --models-path src/models --seeders-path database/seeders --config src/config/config.cjs"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.5"
  }
}
